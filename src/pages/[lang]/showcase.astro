---
import ProductGrid from "../../components/ProductGrid.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { getReleases } from "../../data/releases";
import { isValidLocale } from "../../utils/i18n";
import { locales, translations } from "../../utils/translations";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect("/en/showcase/");
}

const t = translations[lang];
const releases = getReleases(lang);
---

<MainLayout
  lang={lang}
  title={t.seo.showcaseTitle}
  description={t.seo.showcaseDescription}
  slug="showcase"
>
  <ProductGrid
    lang={lang}
    items={releases}
    eyebrow={t.showcase.eyebrow}
    title={t.showcase.title}
    description={t.showcase.description}
    emptyLabel={t.showcase.emptyLabel}
    filledLabel={t.showcase.filledLabel}
    kindApp={t.showcase.kindApp}
    kindGame={t.showcase.kindGame}
    playStore={t.showcase.playStore}
    website={t.showcase.website}
    detailsLabel={t.showcase.detailsLabel}
  />
</MainLayout>
