---
import LegalContent from "../../components/LegalContent.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { isValidLocale } from "../../utils/i18n";
import { locales, translations } from "../../utils/translations";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect("/en/terms/");
}

const t = translations[lang];
---

<MainLayout
  lang={lang}
  title={t.seo.termsTitle}
  description={t.seo.termsDescription}
  slug="terms"
>
  <LegalContent
    title={t.terms.title}
    intro={t.terms.intro}
    sections={t.terms.sections}
    disclaimer={t.terms.disclaimer}
  />
</MainLayout>
