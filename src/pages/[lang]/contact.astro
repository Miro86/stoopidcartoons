---
import ContactLinks from "../../components/ContactLinks.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import { isValidLocale } from "../../utils/i18n";
import { locales, translations } from "../../utils/translations";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect("/en/contact/");
}

const t = translations[lang];
---

<MainLayout
  lang={lang}
  title={t.seo.contactTitle}
  description={t.seo.contactDescription}
  slug="contact"
>
  <ContactLinks
    eyebrow={t.contact.eyebrow}
    title={t.contact.title}
    description={t.contact.description}
    labels={{
      email: t.contact.email,
      legal: t.contact.legal,
      playStore: t.contact.playStore,
      facebook: t.contact.facebook,
      linkedin: t.contact.linkedin,
      x: t.contact.x,
      instagram: t.contact.instagram,
      tiktok: t.contact.tiktok,
      youtube: t.contact.youtube,
    }}
  />
</MainLayout>
