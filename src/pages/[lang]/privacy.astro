---
import LegalContent from '../../components/LegalContent.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import { isValidLocale } from '../../utils/i18n';
import { locales, translations } from '../../utils/translations';

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;

if (!lang || !isValidLocale(lang)) {
  return Astro.redirect('/en/privacy/');
}

const t = translations[lang];
---

<MainLayout
  lang={lang}
  title={t.seo.privacyTitle}
  description={t.seo.privacyDescription}
  slug="privacy"
>
  <LegalContent
    title={t.privacy.title}
    intro={t.privacy.intro}
    sections={t.privacy.sections}
    disclaimer={t.privacy.disclaimer}
  />
</MainLayout>
