---
import { locales, localeMeta } from "../utils/translations";
import { buildPath } from "../utils/i18n";

const baseUrl = import.meta.env.BASE_URL;

const localeLinks = locales.map((lang) => ({
  lang,
  href: buildPath(lang),
  label: localeMeta[lang].nativeLabel,
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>StoopidCartoons</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root {
        color-scheme: dark;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0f0f0f;
        color: #ffffff;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }
      .wrap {
        width: min(42rem, calc(100% - 2rem));
        padding: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1.5rem;
        background: rgba(255, 255, 255, 0.04);
      }
      h1 {
        margin-top: 0;
        font-size: clamp(2rem, 4vw, 3rem);
      }
      p {
        color: rgba(255, 255, 255, 0.72);
        line-height: 1.7;
      }
      .langs {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(7rem, 1fr));
        gap: 0.75rem;
        margin-top: 1.25rem;
      }
      a {
        padding: 0.9rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #fff;
        text-decoration: none;
        text-align: center;
        background: rgba(255, 255, 255, 0.03);
      }
    </style>
    <script is:inline define:vars={{ baseUrl }}>
      const supported = [
        "en",
        "de",
        "fr",
        "it",
        "es",
        "pt",
        "sr",
        "hr",
        "nl",
        "pl",
        "ro",
      ];

      const normalize = (value) => {
        const input = (value || "").toLowerCase();
        if (input.startsWith("de")) return "de";
        if (input.startsWith("sr")) return "sr";
        if (input.startsWith("bs")) return "bs";
        if (input.startsWith("hr")) return "hr";
        if (input.startsWith("fr")) return "fr";
        if (input.startsWith("it")) return "it";
        if (input.startsWith("es")) return "es";
        if (input.startsWith("pt")) return "pt";
        if (input.startsWith("nl")) return "nl";
        if (input.startsWith("pl")) return "pl";
        if (input.startsWith("ro")) return "ro";
        return "en";
      };

      const lang = normalize(navigator.language);
      const destination = `${baseUrl}${lang}/`;

      if (supported.includes(lang) && window.location.pathname === baseUrl) {
        window.location.replace(destination);
      }
    </script>
  </head>
  <body>
    <div class="wrap">
      <h1>StoopidCartoons</h1>
      <p>Choose your language to enter the studio site.</p>
      <div class="langs">
        {localeLinks.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </div>
  </body>
</html>
