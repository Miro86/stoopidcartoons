---
import type { Locale } from "../utils/i18n";
import type { Release } from "../data/releases";
import ReleaseCardGrid from "./ReleaseCardGrid.astro";

interface Props {
  lang: Locale;
  eyebrow: string;
  title: string;
  description: string;
  items: Release[];
  emptyLabel: string;
  filledLabel: string;
  kindApp: string;
  kindGame: string;
  playStore: string;
  website: string;
  detailsLabel?: string;
}

const {
  lang,
  eyebrow,
  title,
  description,
  items,
  emptyLabel,
  filledLabel,
  kindApp,
  kindGame,
  playStore,
  website,
  detailsLabel = "View details",
} = Astro.props;

const hasProducts = items.length > 0;
---

<section class="section">
  <div class="wrapper">
    <div class="section-heading" data-reveal>
      <span class="eyebrow">{eyebrow}</span>
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="section-subtitle" data-reveal>
      <span>{hasProducts ? filledLabel : emptyLabel}</span>
    </div>

    {
      hasProducts && (
        <ReleaseCardGrid
          lang={lang}
          items={items}
          kindApp={kindApp}
          kindGame={kindGame}
          playStore={playStore}
          website={website}
          detailsLabel={detailsLabel}
        />
      )
    }
  </div>
</section>
