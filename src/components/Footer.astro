---
import { siteConfig } from "../config/site";
import type { Locale } from "../utils/i18n";
import { buildPath } from "../utils/i18n";

interface Props {
  lang: Locale;
  nav: {
    home: string;
    showcase: string;
    privacy: string;
    terms: string;
    contact: string;
  };
  footer: {
    tagline: string;
    rights: string;
  };
}

const { lang, nav, footer } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrapper footer-grid">
    <div>
      <div class="brand footer-brand">
        <img
          class="brand-mark"
          src={`${import.meta.env.BASE_URL}logo.png`}
          alt=""
          aria-hidden="true"
        />
        <span class="brand-name">StoopidCartoons</span>
      </div>
      <p class="footer-copy">{footer.tagline}</p>
    </div>

    <div class="footer-links">
      <a href={buildPath(lang)}>{nav.home}</a>
      <a href={buildPath(lang, "showcase")}>{nav.showcase}</a>
      <a href={buildPath(lang, "privacy")}>{nav.privacy}</a>
      <a href={buildPath(lang, "terms")}>{nav.terms}</a>
      <a href={buildPath(lang, "contact")}>{nav.contact}</a>
    </div>

    <div class="footer-links">
      <a
        href={siteConfig.googlePlayDeveloperUrl}
        target="_blank"
        rel="noreferrer">Google Play</a
      >
      <a href={siteConfig.facebookUrl} target="_blank" rel="noreferrer"
        >Facebook</a
      >
      <a href={siteConfig.instagramUrl} target="_blank" rel="noreferrer"
        >Instagram</a
      >

      <a href={siteConfig.xUrl} target="_blank" rel="noreferrer">X</a>
      <a href={siteConfig.tiktokUrl} target="_blank" rel="noreferrer"
        >TikTok</a
      >
      <a href={siteConfig.youtubeUrl} target="_blank" rel="noreferrer"
        >YouTube</a
      >
    </div>
  </div>

  <div class="wrapper footer-bottom">
    <p>© {year} {siteConfig.companyName}. {footer.rights}</p>
  </div>
</footer>
